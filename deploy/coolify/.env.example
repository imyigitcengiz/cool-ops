# Coolify → Application → Environment Variables
# Zorunlu alanları kendi domain ve anahtarınızla doldurun.

DJANGO_SECRET_KEY=uzun-rastgele-gizli-anahtar
DJANGO_ALLOWED_HOSTS=panel.ornek.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://panel.ornek.com
DJANGO_SECURE_SSL=1

# İlk kurulum (giriş: admin / admin) — sonra 0 yapın
DJANGO_ENSURE_SUPERADMIN=1

# Coolify PORT atarsa otomatik kullanılır; sabit 8000 de olur
# PORT=8000

# Kalıcı disk: Coolify UI → Persistent Storage → mount path /data
# (Aşağıdakiler Dockerfile varsayılanıyla aynı; değiştirmeyin.)
# DATA_DIR=/data
# DJANGO_DB_PATH=/data/db.sqlite3
# DJANGO_MEDIA_ROOT=/data/media
# DJANGO_SERVE_MEDIA=1

# WhatsApp — compose.yaml ile whatsapp-bridge servisi kullanın:
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3939
DJANGO_WHATSAPP_BRIDGE_CAN_SPAWN=0

MEDIA_COMPRESS_ENABLED=1
