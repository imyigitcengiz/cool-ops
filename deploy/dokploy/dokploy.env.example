# =============================================================================
# CoolOPS — Dokploy Environment şablonu
# =============================================================================
#
# Dokploy → Project → Docker Compose → Environment sekmesine YAPIŞTIRIN.
# Repo kökünde .env dosyası oluşturmanız gerekmez.
#
# Adımlar:
#   1. APP_URL satırındaki domain'i kendi sslip.io / domain'inizle değiştirin
#   2. Dokploy → Domains → servis "app", port 80, HTTPS kapalı (sslip.io)
#   3. Deploy
#   4. Giriş: admin / admin
#   5. Sonra DJANGO_ENSURE_SUPERADMIN=0 yapıp tekrar deploy
#
# Compose path: docker-compose.yaml
# Overlay bu dosyada COMPOSE_FILE ile tanımlı.
#
# Otomatik (yazmayın — bootstrap-env.sh üretir):
#   DJANGO_SECRET_KEY, DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS,
#   WHATSAPP_BRIDGE_TOKEN
# =============================================================================

# --- Zorunlu (Dokploy) ---
COMPOSE_FILE=docker-compose.yaml:deploy/dokploy/docker-compose.dokploy.yaml

# Traefik / CSRF için tam URL — sonunda / OLMAMALI
# sslip.io → http://  |  kendi domain → https://
APP_URL=http://panel.ornek.sslip.io

# --- İlk kurulum (sonra 0 yapın) ---
DJANGO_ENSURE_SUPERADMIN=1
DJANGO_ALLOW_SSLIP_HOSTS=1

# İlk giriş admin/admin olmuyorsa tek redeploy için açın, sonra kapatın:
# DJANGO_ENSURE_SUPERADMIN_RESET=1

# --- Üretim varsayılanları ---
DJANGO_DEBUG=0

# =============================================================================
# İsteğe bağlı override (çoğu kurulumda gerekmez)
# =============================================================================

# Özel admin şifresi (varsayılan: admin)
# DJANGO_SUPERADMIN_PASSWORD=guclu-sifre

# Coolify benzeri otomatik domain enjekte edilirse APP_URL yerine:
# SERVICE_URL_APP=http://panel.ornek.sslip.io
# SERVICE_FQDN_APP=panel.ornek.sslip.io

# GitHub push → panel içi güncelleme bildirimi
# COOLOPS_UPDATE_REPO=imyigitcengiz/cool-ops
# COOLOPS_UPDATE_BRANCH=main

# Coolify webhook ile redeploy (Dokploy kendi webhook'unu kullanır)
# COOLOPS_DEPLOY_WEBHOOK_URL=

# Geçici test — üretimde kullanmayın
# GY_ALLOW_EPHEMERAL_DATA=1
