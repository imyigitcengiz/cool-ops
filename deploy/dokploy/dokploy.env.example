# =============================================================================
# CoolOPS — Dokploy Environment şablonu
# Domain: Domains → servis app, port 80 (otomatik SERVICE_FQDN_APP)
# Ortak şablon: deploy/panel.env.template · deploy/DOMAIN.md
# =============================================================================
#
# Dokploy → Project → Docker Compose → Environment sekmesine YAPIŞTIRIN.
#
# Adımlar:
#   1. Domains → servis "app", port 80
#   2. Deploy (domain otomatik)
#   3. Giriş: admin / admin
#   4. Sonra DJANGO_ENSURE_SUPERADMIN=0
#
# Otomatik (yazmayın — bootstrap-env.sh + panel-domain.sh):
#   DJANGO_SECRET_KEY, DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS
# =============================================================================

COMPOSE_FILE=docker-compose.yaml:deploy/dokploy/docker-compose.dokploy.yaml

DJANGO_ENSURE_SUPERADMIN=0
DJANGO_DEBUG=0

# İlk giriş sorunu: DJANGO_ENSURE_SUPERADMIN_RESET=1 (tek redeploy)

# GitHub push bildirimi (isteğe bağlı)
# COOLOPS_UPDATE_REPO=imyigitcengiz/cool-ops
# COOLOPS_UPDATE_BRANCH=main
