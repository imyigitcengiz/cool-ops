# CoolOPS — Dockerfile / Nixpacks (tek konteyner)
# Panel → Environment: deploy/panel.env.template · deploy/DOMAIN.md
#
# ZORUNLU: Persistent Storage → mount path /data
# Domain: panel UI domain tanımı → SERVICE_FQDN_APP (Coolify) veya KOBIOPS_DOMAIN

DJANGO_ENSURE_SUPERADMIN=0
DJANGO_DEBUG=0

# Tek konteyner — WhatsApp köprüsü yok
DJANGO_WHATSAPP_BRIDGE_WAIT_ON_START=0

# bootstrap otomatik üretir; elle yazmayın:
# DJANGO_SECRET_KEY, DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS, APP_URL
