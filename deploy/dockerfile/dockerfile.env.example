# CoolOPS — Dockerfile / Nixpacks (tek konteyner)
# Panel → Environment sekmesine yapıştırın.
#
# ZORUNLU: Persistent Storage → mount path /data
# Build: Dockerfile (repo kökü)
# Port: panelin verdiği PORT (Coolify genelde 3000) — dokunmayın

APP_URL=http://panel.ornek.sslip.io
DJANGO_ENSURE_SUPERADMIN=1
DJANGO_ALLOW_SSLIP_HOSTS=1
DJANGO_DEBUG=0

# Tek konteyner — WhatsApp köprüsü yok (Compose kullanmıyorsanız)
DJANGO_WHATSAPP_BRIDGE_WAIT_ON_START=0

# bootstrap otomatik üretir; elle yazmayın:
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=
# DJANGO_CSRF_TRUSTED_ORIGINS=
