# =============================================================================
# CoolOPS — 1Panel Compose ortam değişkenleri
# Domain: Web sitesi / reverse proxy ekledikten sonra KOBIOPS_DOMAIN
# Ortak şablon: deploy/panel.env.template · deploy/DOMAIN.md
# =============================================================================
#
# 1Panel → Konteyner → Compose → Ortam değişkenleri
#
# Compose dosyası: docker-compose.yaml
# Zorunlu overlay (port 80 çakışmasını önler):
# =============================================================================

COMPOSE_FILE=docker-compose.yaml:deploy/1panel/docker-compose.1panel.yaml

# OpenResty/nginx arkasındaki public domain
KOBIOPS_DOMAIN=panel.sizin-domain.com

# localhost proxy hedefi (1Panel overlay: 127.0.0.1:8080→80)
KOBIOPS_HTTP_PORT=8080

# KOBIOPS_PUBLIC_URL otomatik https:// (bootstrap)

DJANGO_ENSURE_SUPERADMIN=0
DJANGO_DEBUG=0
