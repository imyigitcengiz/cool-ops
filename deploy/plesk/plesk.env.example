# =============================================================================
# CoolOPS — Plesk Git deploy ortamı (ZORUNLU)
# =============================================================================
#
# cp deploy/plesk/plesk.env.example deploy/plesk/plesk.env
# deploy/plesk/plesk.env git'e girmez.
#
# Coolify/sslip.io burada YOK — sadece kendi Plesk domain'iniz.
# deploy.sh her çalışmada .env içindeki eski APP_URL / SERVICE_* temizler.
# =============================================================================

# Kendi subdomain'iniz (ör. ops.yigitcengiz.co)
KOBIOPS_DOMAIN=ops.yigitcengiz.co

# nginx proxy hedefi (deploy/plesk/nginx-proxy.conf ile aynı port)
KOBIOPS_HTTP_PORT=8000

DJANGO_ENSURE_SUPERADMIN=1

# KOBIOPS_PUBLIC_URL otomatik https://
