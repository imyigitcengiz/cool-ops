# Plesk sunucusunda bir kez kopyalayın:
#   cp deploy/plesk/plesk.env.example deploy/plesk/plesk.env
#
# deploy/plesk/plesk.env git'e girmez (yerel kurulum ayarı).

# Subdomain veya tam domain (SSL Plesk'te açık olmalı)
KOBIOPS_DOMAIN=ops.yigitcengiz.co

# Plesk reverse proxy hedefi (nginx → bu port)
KOBIOPS_HTTP_PORT=8080

# İlk kurulumda admin/admin oluşturmak için 1, sonra 0 yapın
DJANGO_ENSURE_SUPERADMIN=1

# Otomatik — https kullanıyorsanız boş bırakın
# KOBIOPS_PUBLIC_URL=https://ops.yigitcengiz.co
