# Plesk → Docker → Stacks → stack ortam değişkenleri
# Kopya: cp deploy/plesk/plesk-stack.env.example deploy/plesk/plesk-stack.env
# (plesk-stack.env git'e girmez — .gitignore)

KOBIOPS_DOMAIN=ops.ornek.com
KOBIOPS_HTTP_PORT=8000
KOBIOPS_PUBLIC_URL=https://ops.ornek.com

# İlk kurulumda admin/admin; sonra 0
DJANGO_ENSURE_SUPERADMIN=1
